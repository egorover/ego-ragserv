# ==============================================================================
# RAG Vector Demo - Environment Configuration Template
# ==============================================================================
# Copy this file to .env and fill in your API keys
# Command: cp env.template .env (Linux/Mac) or copy env.template .env (Windows)
# ==============================================================================

# ------------------------------------------------------------------------------
# OpenAI Configuration (REQUIRED)
# ------------------------------------------------------------------------------
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Embedding model to use (default: text-embedding-3-large)
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIMENSION=3072

# ------------------------------------------------------------------------------
# Pinecone Configuration (REQUIRED)
# ------------------------------------------------------------------------------
# Get your API key from: https://app.pinecone.io/
PINECONE_API_KEY=your_pinecone_api_key_here

# Environment/Region (e.g., us-east-1-aws, us-west-2-aws, eu-west-1-aws)
PINECONE_ENVIRONMENT=your_pinecone_environment_here

# Index name (will be created if doesn't exist)
PINECONE_INDEX_NAME=rag-demo-index

# ------------------------------------------------------------------------------
# Weaviate Configuration (REQUIRED)
# ------------------------------------------------------------------------------
# Local Weaviate: http://localhost:8080
# Weaviate Cloud: https://your-cluster.weaviate.network
WEAVIATE_URL=your_weaviate_url_here

# API key (optional for local, required for cloud)
# Leave empty if using local Weaviate without authentication
WEAVIATE_API_KEY=your_weaviate_api_key_here

# Class name for collections
WEAVIATE_CLASS_NAME=RAGDocument

# ------------------------------------------------------------------------------
# Relevance AI Configuration (OPTIONAL)
# ------------------------------------------------------------------------------
# !!! Relevance более НЕ ПРЕДСТАВЛЯЕТ векторного хранилища !!!
# Get your credentials from: https://cloud.relevance.ai/
RELEVANCE_PROJECT=your_relevance_project_id_here
RELEVANCE_API_KEY=your_relevance_api_key_here
RELEVANCE_DATASET_ID=rag-demo-dataset

# ------------------------------------------------------------------------------
# ProxyAPI Configuration (OPTIONAL)
# ------------------------------------------------------------------------------
# Russian ProxyAPI service: https://proxyapi.ru
# Enable to route OpenAI requests through ProxyAPI
#
PROXYAPI_API_KEY=your_proxyapi_api_key_here
PROXYAPI_BASE_URL=https://api.proxyapi.ru/openai/v1
PROXYAPI_ENABLED=false

# ==============================================================================
# Quick Start Guide
# ==============================================================================
# 1. Copy this file to .env: cp env.template .env (Linux/Mac)
#    или copy env.template .env (Windows)
# 2. Fill in at minimum:
#    - OPENAI_API_KEY (если не используете ProxyAPI)
#    - PINECONE_API_KEY
#    - PINECONE_ENVIRONMENT
#    - WEAVIATE_URL
# 3. Enable ProxyAPI (optional):
#    Set PROXYAPI_ENABLED=true and PROXYAPI_API_KEY
# 4. Test your setup:
#    python scripts/check_setup.py
# 5. Run the demo:
#    python examples/demo_usage.py
# ==============================================================================
